# ================================================================
# Variables d'environnement — Serveur MCP Dendreo
# ================================================================
# Copiez ce fichier en .env et remplissez vos valeurs.
# ⚠️  Ne commitez JAMAIS le fichier .env dans git !

# URL de base de votre API Dendreo
# Format : https://pro.dendreo.com/VOTRE_COMPTE/api
# Remplacez VOTRE_COMPTE par le nom de votre compte Dendreo
DENDREO_BASE_URL=https://pro.dendreo.com/VOTRE_COMPTE/api

# Votre clé API Dendreo
# Disponible dans Dendreo > Configuration > API
DENDREO_API_KEY=votre_cle_api_ici

# Port d'écoute du serveur (Railway le définit automatiquement)
PORT=3000
